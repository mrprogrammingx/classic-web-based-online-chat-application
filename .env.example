# Presence speed for tests (short so presence state transitions are quick)
PRESENCE_ONLINE_SECONDS=3

# Test upload directory (keeps test uploads isolated)
TEST_UPLOAD_DIR=uploads_test

# Skip sending real emails during tests
SKIP_EMAIL_DELIVERY=true

# Database busy timeout in milliseconds (used by some DB wrappers)
DB_BUSY_TIMEOUT_MS=5000

# Feature flags useful during testing
FEATURE_NOTIFICATIONS=true
FEATURE_WEBSOCKETS=false

# Logging/verbosity for tests
LOG_LEVEL=DEBUG

# General test mode flag (can be used by app to enable test-only hooks)
APP_TESTING=true
